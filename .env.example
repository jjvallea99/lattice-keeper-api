# ── Lattice Keeper Environment ──────────────────────────────────────────────
# Copy this file to .env and fill in values before running docker compose up

# REQUIRED: Set a strong random API key
LATTICE_API_KEY=replace_with_strong_random_key

# Bitcoin: false = testnet (safe for dev), true = mainnet (real money)
LATTICE_BTC_MAINNET=false

# Bitcoin RPC credentials (must match bitcoin-core service settings)
BITCOIN_RPC_USER=lattice
BITCOIN_RPC_PASS=changeme

# Lightning: false = simulated invoices (safe for dev)
LATTICE_LIGHTNING_ENABLED=false

# Debug logging
DEBUG=false
